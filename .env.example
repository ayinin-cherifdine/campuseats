# Backend API URL
# - Web (Docker): leave empty — nginx proxies /api/ to backend on same origin
# - Mobile (Expo Go on device): set to your machine's LAN IP, e.g. http://192.168.1.10:8000
# - Mobile (Expo Go on same machine): http://localhost:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Legacy Supabase keys (no longer used — kept for reference)
# EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
