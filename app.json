{
  "expo": {
    "name": "CampusEats",
    "slug": "campuseats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "campuseats",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campuseats.app",
      "infoPlist": {
        "NSAllowsArbitraryLoads": true,
        "NSAllowsLocalNetworking": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.campuseats.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CampusEats to access your photos to select food videos.",
          "cameraPermission": "Allow CampusEats to use the camera to record food videos.",
          "microphonePermission": "Allow CampusEats to access the microphone for video recording."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow CampusEats to use your location to find restaurants near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
